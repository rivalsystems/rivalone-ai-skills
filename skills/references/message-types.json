    "enrichment": {
      "summary": "Wire payloads from Rival keep numeric ResponseType only. For logs, UI, or assistant-visible copies, add optional sidecar keys — never remove or replace the number.",
      "dispatchRule": "Applications and event handlers must branch on the numeric ResponseType (or raw server JSON). Do not require parsing string names for routing.",
      "forAgents": "When showing inbound frames to the user, always show the numeric ResponseType; you may append _responseTypeName and _responseTypeLabel (from responseTypesById) on a copy for readability.",
      "optionalKeys": {
        "_responseTypeName": "Stable identifier (the `name` field) for logs and human scan.",
        "_responseTypeLabel": "Doc-style title (the `label` field).",
        "_keyPrefixRationale": "Leading underscore reduces overlap with vendor field names in ResponseData."
      }
    }
  },
