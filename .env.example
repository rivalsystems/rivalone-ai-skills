# Copy to .env for local development of YOUR Rival One client (never commit real values).
# Documented in README.md and skills/catalog/auth-basics.md.

# --- Mode A: pre-built JWT ---
# RIVAL_ONE_API_TOKEN=

# --- Mode B: build JWT locally (HS512) ---
# RIVAL_ONE_API_KEY=
# RIVAL_ONE_SECRET_KEY=
# RIVAL_ONE_GROUP=
# RIVAL_ONE_USER=
# RIVAL_ONE_USERNAME=

# RIVAL_ONE_JWT_SUB=
# Optional JWT claim firm when Rival requires firm scoping on login:
# RIVAL_ONE_FIRM=
RIVAL_ONE_WSS_URL=wss://sim-api.rivalsystems.cloud:50443
RIVAL_ONE_PING_INTERVAL_SECONDS=240
# RIVAL_ONE_DEFAULT_ACCOUNT=
